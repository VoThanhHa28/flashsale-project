    {
      "name": "✅ Test 1: Normal Flow - Happy Path",
      "item": [
        {
          "name": "1.1 POST /order (Normal Buy)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse response\n",
                  "let jsonData = pm.response.json();\n",
                  "\n",
                  "pm.test('✅ Status 200 OK', () => {\n",
                  "  pm.expect(pm.response.code).to.equal(200);\n",
                  "});\n",
                  "\n",
                  "pm.test('✅ Response has client_order_id', () => {\n",
                  "  pm.expect(jsonData.data.client_order_id).to.exist;\n",
                  "});\n",
                  "\n",
                  "pm.test('✅ Response has reservation_id', () => {\n",
                  "  pm.expect(jsonData.data.reservation_id).to.exist;\n",
                  "});\n",
                  "\n",
                  "pm.test('✅ Order payload has required fields', () => {\n",
                  "  let order = jsonData.data.order;\n",
                  "  pm.expect(order.userId).to.exist;\n",
                  "  pm.expect(order.productId).to.exist;\n",
                  "  pm.expect(order.quantity).to.equal(1);\n",
                  "  pm.expect(order.price).to.exist;\n",
                  "});\n",
                  "\n",
                  "// Save for later tests\n",
                  "pm.globals.set('client_order_id_1', jsonData.data.client_order_id);\n",
                  "pm.globals.set('reservation_id_1', jsonData.data.reservation_id);\n",
                  "\n",
                  "// Log response time\n",
                  "pm.test('✅ Response time < 100ms', () => {\n",
                  "  pm.expect(pm.response.responseTime).to.be.below(100);\n",
                  "});\n"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_id}}\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:3000/v1/api/order/buy",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["v1", "api", "order", "buy"]
            }
          }
        },
        {
          "name": "1.2 Verify Reservation Created (pending)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = pm.response.json();\n",
                  "\n",
                  "pm.test('✅ Reservation status = pending', () => {\n",
                  "  pm.expect(jsonData.status).to.equal('pending');\n",
                  "});\n",
                  "\n",
                  "pm.test('✅ Reservation has client_order_id', () => {\n",
                  "  pm.expect(jsonData.client_order_id).to.equal(pm.globals.get('client_order_id_1'));\n",
                  "});\n",
                  "\n",
                  "pm.test('✅ Reservation has expire_at (TTL)', () => {\n",
                  "  pm.expect(jsonData.expire_at).to.exist;\n",
                  "  // Should be ~30 minutes from now\n",
                  "  let expireTime = new Date(jsonData.expire_at).getTime();\n",
                  "  let now = Date.now();\n",
                  "  let diffMinutes = (expireTime - now) / 60000;\n",
                  "  pm.expect(diffMinutes).to.be.above(29);\n",
                  "  pm.expect(diffMinutes).to.be.below(31);\n",
                  "});\n"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
