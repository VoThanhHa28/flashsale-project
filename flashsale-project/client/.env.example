# Backend API URL (bỏ trống hoặc không set = tự dùng mock data)
REACT_APP_API_URL=http://localhost:3002

# Mock mode toggle:
#   true  = luôn dùng mock data (không gọi backend)
#   false = luôn gọi real API
#   (bỏ trống) = tự detect: nếu REACT_APP_API_URL trống → mock, ngược lại → real
REACT_APP_USE_MOCK=true
